@model BookHive.Models.User
@{
    ViewData["Title"] = "User Information";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BookHive - User Information</title>
    <link rel="stylesheet" href="~/css/output.css" />
</head>
<body class="bg-slate-100 font-sans m-0">

    <div class="flex min-h-screen">

        @* Sidebar *@
        <aside class="w-[220px] bg-[#1B2B5E] flex flex-col p-3.5 flex-shrink-0 min-h-screen">
            <div class="flex items-center gap-2.5 mb-8 pl-1 text-white text-lg font-extrabold">
                <div class="w-9 h-9 rounded-full bg-[#F5C518] flex items-center justify-center text-[15px] font-extrabold text-[#1B2B5E] flex-shrink-0">
                    B
                </div>
                <span>BookHive</span>
            </div>
            <nav class="flex flex-col gap-1 flex-1">
                <a href="/MIS/Dashboard"
                   class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-[13px] font-medium text-[#B0C4DE] hover:bg-white/10 hover:text-white transition-colors">
                    <span class="text-base">&#127968;</span> Dashboard
                </a>
                <a href="/MIS/Registration"
                   class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-[13px] font-medium text-[#B0C4DE] hover:bg-white/10 hover:text-white transition-colors">
                    <span class="text-base">&#43;</span> Registration
                </a>
                <div>
                    <div class="flex items-center rounded-lg bg-white/15">
                        <a href="/MIS/UserInfo" style="color:#fff;text-decoration:none;display:flex;align-items:center;gap:10px;flex:1;padding:10px 12px;font-size:13px;font-weight:700;">
                            <span style="font-size:15px;">&#128100;</span> User Information
                        </a>
                        <button onclick="toggleUserMenu()" style="background:none;border:none;cursor:pointer;color:#fff;padding:10px 8px;">
                            <svg id="userMenuArrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transition:transform 0.2s;display:block;"><polyline points="6 9 12 15 18 9"></polyline></svg>
                        </button>
                    </div>
                    <div id="userSubMenu" style="display:none" class="flex flex-col mt-0.5 pl-4">
                        <a href="/MIS/ArchivedUsers"
                           class="flex items-center gap-2 px-3 py-2 rounded-lg text-[12px] font-medium text-[#B0C4DE] hover:bg-white/10 hover:text-white transition-colors">
                            <span>&#128452;</span> Archived Users
                        </a>
                    </div>
                </div>
            </nav>
            <a href="/MIS/Logout"
               class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-[13px] text-[#90A4AE] hover:bg-white/[0.07] transition-colors">
                &#128682; Logout
            </a>
        </aside>

        @* Main *@
        <div class="flex-1 flex flex-col">

            @* Header *@
            <header class="bg-white border-b border-slate-200 px-7 py-4 flex justify-between items-center flex-shrink-0">
                <div>
                    <h1 class="text-xl font-bold text-[#1B2B5E] m-0">User Information</h1>
                    <p class="text-xs text-slate-500 mt-0.5">
                        MIS Facilitator Portal STI San Jose Del Monte
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="w-[38px] h-[38px] rounded-full bg-[#F5C518] flex items-center justify-center text-[13px] font-extrabold text-[#1B2B5E]">
                        MF
                    </span>
                </div>
            </header>

            @* Content *@
            <main class="p-7 flex flex-col gap-5">

                @* Back link points to the USER LIST *@
                <a href="/MIS/UserInfo"
                   class="inline-block text-blue-600 text-[13px] font-semibold no-underline hover:underline">
                    &larr; Back to User Information
                </a>

                @* Success banner — shows once after a Reset Password redirect *@
                @if (TempData["Toast"] != null)
                {
                    <div class="bg-green-50 border border-green-300 text-green-800 rounded-lg px-3.5 py-2.5 text-[13px] font-semibold">
                        ✅ @TempData["Toast"]
                    </div>
                }

                <div id="toast"
                     class="hidden fixed bottom-6 right-6 bg-[#1B2B5E] text-white px-5 py-3 rounded-[10px] text-[13px] font-semibold z-[1000] shadow-[0_4px_16px_rgba(0,0,0,0.2)]">
                </div>

                @* Profile Card *@
                <div class="bg-[#1B2B5E] rounded-xl px-[26px] py-[22px] flex items-center gap-[18px] text-white">
                    <div class="w-14 h-14 rounded-full bg-[#F5C518] text-[#1B2B5E] flex items-center justify-center text-lg font-extrabold flex-shrink-0">
                        @Model.Initials
                    </div>
                    <div class="flex-1">
                        <h2 class="text-xl font-extrabold mb-1">@Model.FullName</h2>
                        <p class="text-xs text-[#B0C4DE] my-0.5">
                            @Model.Role &middot; @Model.Email
                        </p>
                        <p class="text-xs text-[#B0C4DE] my-0.5">
                            Registered: @Model.CreatedAt.ToString("yyyy-MM-dd")
                        </p>
                    </div>
                    <span id="statusBadge"
                          class="@(Model.Status == "Active" ? "bg-green-100 text-green-700" : "bg-red-100 text-red-600") rounded-full px-3 py-1 text-[13px] font-semibold">
                        @Model.Status
                    </span>
                </div>

                @* Account Details *@
                <div class="bg-white rounded-[10px] px-[26px] py-[22px] border border-slate-200">
                    <h3 class="text-[15px] font-bold text-[#1B2B5E] mb-4">Account Details</h3>
                    <div class="grid grid-cols-3 gap-x-6 gap-y-4">
                        <div class="flex flex-col gap-0.5">
                            <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wide">ID / Emp. No.</span>
                            <span class="text-[13px] text-slate-800 font-medium">@(Model.StudId ?? Model.EmpId)</span>
                        </div>
                        <div class="flex flex-col gap-0.5">
                            <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wide">Role</span>
                            <span class="text-[13px] text-slate-800 font-medium">@Model.Role</span>
                        </div>
                        <div class="flex flex-col gap-0.5">
                            <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wide">Last Name</span>
                            <span class="text-[13px] text-slate-800 font-medium">@Model.LastName</span>
                        </div>
                        <div class="flex flex-col gap-0.5">
                            <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wide">First Name</span>
                            <span class="text-[13px] text-slate-800 font-medium">@Model.FirstName</span>
                        </div>
                        <div class="flex flex-col gap-0.5">
                            <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wide">Email Address</span>
                            <span class="text-[13px] text-slate-800 font-medium">@Model.Email</span>
                        </div>
                        <div class="flex flex-col gap-0.5">
                            <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wide">Phone Number</span>
                            <span class="text-[13px] text-slate-800 font-medium">@Model.Phone</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Department))
                        {
                            <div class="flex flex-col gap-0.5">
                                <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wide">Department</span>
                                <span class="text-[13px] text-slate-800 font-medium">@Model.Department</span>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.RFIDCard))
                        {
                            <div class="flex flex-col gap-0.5">
                                <span class="text-[10px] font-semibold text-slate-500 uppercase tracking-wide">RFID Card No.</span>
                                <span class="text-[13px] text-slate-800 font-medium">@Model.RFIDCard</span>
                            </div>
                        }
                    </div>
                </div>

                @* Account Management *@
                <div class="bg-white rounded-[10px] px-6.5 py-5.5 px-[26px] py-[22px] border border-slate-200">
                    <h3 class="text-[15px] font-bold text-[#1B2B5E] mb-4">Account Management</h3>
                    <div class="grid grid-cols-3 gap-3.5">

                        <div class="bg-slate-50 rounded-[10px] p-4.5 flex flex-col border border-slate-200">
                            <span class="text-[26px] mb-2.5">&#128273;</span>
                            <h4 class="text-[13px] font-bold text-[#1B2B5E] mb-1.5">Reset Password</h4>
                            <p class="text-[11px] text-slate-500 leading-relaxed mb-3.5 flex-1">
                                Generate a new temporary password for this account.
                            </p>
                            <button type="button"
                                    onclick="openModal('modalResetPass')"
                                    class="bg-blue-600 text-white border-none rounded-lg px-4 py-2 text-xs font-bold cursor-pointer hover:opacity-90 transition-opacity mt-auto">
                                Reset Password
                            </button>
                        </div>

                        <div class="bg-slate-50 rounded-[10px] p-4.5 flex flex-col border border-slate-200">
                            <span class="text-[26px] mb-2.5">&#128272;</span>
                            <h4 class="text-[13px] font-bold text-[#1B2B5E] mb-1.5">Reset Authenticator</h4>
                            <p class="text-[11px] text-slate-500 leading-relaxed mb-3.5 flex-1">
                                Clear 2FA so the user can re-enroll on next login.
                            </p>
                            <button type="button"
                                    onclick="resetAuthenticator()"
                                    class="bg-orange-600 text-white border-none rounded-lg px-4 py-2 text-xs font-bold cursor-pointer hover:opacity-90 transition-opacity mt-auto">
                                Reset Auth
                            </button>
                        </div>

                        <div class="bg-slate-50 rounded-[10px] p-4.5 flex flex-col border border-slate-200">
                            <span class="text-[26px] mb-2.5">&#128452;</span>
                            <h4 class="text-[13px] font-bold text-[#1B2B5E] mb-1.5">Archive Account</h4>
                            <p class="text-[11px] text-slate-500 leading-relaxed mb-3.5 flex-1">
                                Deactivate this account and remove system access.
                            </p>
                            <button type="button"
                                    onclick="openModal('modalArchive')"
                                    class="bg-red-600 text-white border-none rounded-lg px-4 py-2 text-xs font-bold cursor-pointer hover:opacity-90 transition-opacity mt-auto">
                                Archive
                            </button>
                        </div>

                    </div>
                </div>

            </main>
        </div>
    </div>

    @* MODAL: Reset Password — auto-generated, persists to database *@
    <div id="modalResetPass"
         class="hidden fixed inset-0 bg-black/45 flex items-center justify-center z-[900]">
        <div class="bg-white rounded-2xl px-8 py-7 w-[420px] shadow-[0_8px_40px_rgba(0,0,0,0.2)]">
            <div class="flex justify-between items-center mb-3.5">
                <h3 class="text-[17px] font-bold text-[#1B2B5E]">Reset Password</h3>
                <button type="button"
                        onclick="closeModal('modalResetPass')"
                        class="bg-transparent border-none text-lg cursor-pointer text-slate-500 hover:text-[#1B2B5E] transition-colors p-1">
                    &#10005;
                </button>
            </div>

            <p class="text-[13px] text-slate-500 leading-relaxed mb-4">
                A new password has been auto-generated for
                <strong>@Model.FullName</strong>.
            </p>

            <form id="resetPassForm" method="post" action="/MIS/ResetPassword">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />

                <div class="flex flex-col mb-3">
                    <label class="text-xs font-semibold text-[#1B2B5E] mb-1.5">New Password</label>
                    <div class="relative flex gap-2">
                        <input type="text"
                               id="newPass"
                               name="newPassword"
                               readonly
                               maxlength="20"
                               class="flex-1 px-3 py-2.5 rounded-lg border-2 border-[#1B2B5E] text-base font-bold tracking-[2px] outline-none font-mono bg-white text-[#1B2B5E]" />
                        <button type="button"
                                onclick="generatePassword()"
                                title="Generate new password"
                                class="bg-[#1B2B5E] text-white border-none rounded-lg px-3.5 text-base cursor-pointer hover:bg-[#162347] transition-colors">
                            &#128260;
                        </button>
                    </div>
                </div>

                <div class="flex justify-end gap-2.5 mt-[18px]">
                    <button type="button"
                            onclick="closeModal('modalResetPass')"
                            class="bg-transparent border border-slate-200 rounded-lg px-5 py-2 text-[13px] cursor-pointer text-slate-500 font-semibold hover:border-slate-400 transition-colors">
                        Cancel
                    </button>
                    <button type="submit"
                            class="bg-blue-600 text-white border-none rounded-lg px-5 py-2 text-[13px] font-bold cursor-pointer hover:opacity-90 transition-opacity">
                        Confirm Reset
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* MODAL: Archive Account *@
    <div id="modalArchive"
         class="hidden fixed inset-0 bg-black/45 flex items-center justify-center z-[900]">
        <div class="bg-white rounded-2xl px-8 py-7 w-[420px] shadow-[0_8px_40px_rgba(0,0,0,0.2)]">
            <div class="flex justify-between items-center mb-3.5">
                <h3 class="text-[17px] font-bold text-[#1B2B5E]">Archive Account</h3>
                <button type="button"
                        onclick="closeModal('modalArchive')"
                        class="bg-transparent border-none text-lg cursor-pointer text-slate-500 hover:text-[#1B2B5E] transition-colors p-1">
                    &#10005;
                </button>
            </div>
            <p class="text-[13px] text-slate-500 leading-relaxed mb-4">
                Are you sure you want to archive the account of
                <strong>@Model.FullName</strong>?
                This will move them to the Archived Users list.
            </p>
            <form id="archiveForm" method="post" action="/MIS/ArchiveUser">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
            </form>
            <div class="flex justify-end gap-2.5">
                <button type="button"
                        onclick="closeModal('modalArchive')"
                        class="bg-transparent border border-slate-200 rounded-lg px-5 py-2 text-[13px] cursor-pointer text-slate-500 font-semibold hover:border-slate-400 transition-colors">
                    Cancel
                </button>
                <button type="button"
                        onclick="document.getElementById('archiveForm').submit()"
                        class="bg-red-600 text-white border-none rounded-lg px-5 py-2 text-[13px] font-bold cursor-pointer hover:opacity-90 transition-opacity">
                    Archive
                </button>
            </div>
        </div>
    </div>

    <script src="~/js/mis-userinfo.js"></script>
    <script>
        function toggleUserMenu() {
            const menu = document.getElementById('userSubMenu');
            const arrow = document.getElementById('userMenuArrow');
            const isHidden = menu.style.display === 'none';
            menu.style.display = isHidden ? 'flex' : 'none';
            arrow.style.transform = isHidden ? 'rotate(180deg)' : '';
        }
    </script>
</body>
</html>