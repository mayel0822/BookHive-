@{
    ViewData["Title"] = "MIS Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BookHive - MIS Login</title>
    <link rel="stylesheet" href="~/css/output.css" />
</head>
<body class="min-h-screen flex font-sans">

    <!-- Left Panel -->
    <div class="flex-1 bg-[#1B2B5E] flex flex-col items-center justify-center px-10 py-12 text-white">
        <div class="w-20 h-20 rounded-full bg-[#F5C518] flex items-center justify-center text-[32px] font-extrabold text-[#1B2B5E] mb-5">
            B
        </div>
        <h1 class="text-4xl font-extrabold mb-1.5 tracking-wide">BookHive</h1>
        <p class="text-[11px] text-[#F5C518] font-semibold tracking-[2px] mb-4">MIS FACILITATOR PORTAL</p>
        <p class="text-sm text-[#B0BEC5] text-center max-w-[260px] leading-relaxed">
            Manage accounts and system access for
            STI San Jose Del Monte Library.
        </p>
    </div>

    <!-- Right Panel -->
    <div class="flex-1 bg-slate-100 flex items-center justify-center p-8">
        <div class="bg-white rounded-2xl px-9 py-10 w-full max-w-[400px] shadow-[0_4px_24px_rgba(0,0,0,0.08)]">

            <h2 class="text-2xl font-bold text-[#1B2B5E] mb-1">Welcome, Admin</h2>
            <p class="text-sm text-slate-500 mb-8">Sign in to your MIS account</p>

            <a href="/MIS/MicrosoftLogin"
               class="w-full flex items-center justify-center gap-3 bg-white border border-slate-300 rounded-lg py-3 text-[15px] font-semibold text-slate-700 hover:bg-slate-50 transition-colors no-underline">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 21 21">
                    <rect x="1" y="1" width="9" height="9" fill="#f25022" />
                    <rect x="11" y="1" width="9" height="9" fill="#00a4ef" />
                    <rect x="1" y="11" width="9" height="9" fill="#7fba00" />
                    <rect x="11" y="11" width="9" height="9" fill="#ffb900" />
                </svg>
                Log in with Microsoft
            </a>

        </div>
    </div>

</body>
</html>
