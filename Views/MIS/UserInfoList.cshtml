@model List<BookHive.Models.User>
@{
    ViewData["Title"] = "User Information";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BookHive - User Information</title>
    <link rel="stylesheet" href="~/css/output.css" />
</head>
<body class="bg-slate-100 font-sans m-0">

    <div class="flex min-h-screen">

        @* Sidebar *@
        <aside class="w-[220px] bg-[#1B2B5E] flex flex-col p-3.5 flex-shrink-0 min-h-screen">
            <div class="flex items-center gap-2.5 mb-8 pl-1 text-white text-lg font-extrabold">
                <div class="w-9 h-9 rounded-full bg-[#F5C518] flex items-center justify-center text-[15px] font-extrabold text-[#1B2B5E] flex-shrink-0">
                    B
                </div>
                <span>BookHive</span>
            </div>
            <nav class="flex flex-col gap-1 flex-1">
                <a href="/MIS/Dashboard"
                   class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-[13px] font-medium text-[#B0C4DE] hover:bg-white/10 hover:text-white transition-colors">
                    <span class="text-base">&#127968;</span> Dashboard
                </a>
                <a href="/MIS/Registration"
                   class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-[13px] font-medium text-[#B0C4DE] hover:bg-white/10 hover:text-white transition-colors">
                    <span class="text-base">&#43;</span> Registration
                </a>
                <div>
                    <div class="flex items-center rounded-lg bg-white/15">
                        <a href="/MIS/UserInfo" style="color:#fff;text-decoration:none;display:flex;align-items:center;gap:10px;flex:1;padding:10px 12px;font-size:13px;font-weight:700;">
                            <span style="font-size:15px;">&#128100;</span> User Information
                        </a>
                        <button onclick="toggleUserMenu()" style="background:none;border:none;cursor:pointer;color:#fff;padding:10px 8px;">
                            <svg id="userMenuArrow" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transition:transform 0.2s;display:block;"><polyline points="6 9 12 15 18 9"></polyline></svg>
                        </button>
                    </div>
                    <div id="userSubMenu" style="display:none" class="flex flex-col mt-0.5 pl-4">
                        <a href="/MIS/ArchivedUsers"
                           class="flex items-center gap-2 px-3 py-2 rounded-lg text-[12px] font-medium text-[#B0C4DE] hover:bg-white/10 hover:text-white transition-colors">
                            <span>&#128452;</span> Archived Users
                        </a>
                    </div>
                </div>
            </nav>
            <a href="/MIS/Logout"
               class="flex items-center gap-2.5 px-3 py-2.5 rounded-lg text-[13px] text-[#90A4AE] hover:bg-white/[0.07] transition-colors">
                &#128682; Logout
            </a>
        </aside>

        @* Main *@
        <div class="flex-1 flex flex-col">

            @* Header *@
            <header class="bg-white border-b border-slate-200 px-7 py-4 flex justify-between items-center flex-shrink-0">
                <div>
                    <h1 class="text-xl font-bold text-[#1B2B5E] m-0">User Information</h1>
                    <p class="text-xs text-slate-500 mt-0.5">
                        MIS Facilitator Portal STI San Jose Del Monte
                    </p>
                </div>
                <div class="flex items-center gap-3">
                    <span class="w-[38px] h-[38px] rounded-full bg-[#F5C518] flex items-center justify-center text-[13px] font-extrabold text-[#1B2B5E]">
                        MF
                    </span>
                </div>
            </header>

            @* Content *@
            <main class="p-7">

                <div class="bg-white rounded-[10px] border border-slate-200 overflow-hidden">

                    @* Toolbar *@
                    <div class="px-5 pt-4 pb-2.5 flex justify-between items-center">
                        <span class="text-base font-bold text-[#1B2B5E]">All Users</span>
                        <div class="flex gap-2.5 items-center">
                            <input type="text"
                                   id="searchInput"
                                   placeholder="Search name, ID, email..."
                                   onkeyup="filterTable()"
                                   class="px-3.5 py-2 rounded-lg border border-slate-200 text-xs w-[220px] outline-none focus:border-blue-600" />
                        </div>
                    </div>

                    @* Role Filter Buttons *@
                    <div class="px-5 pb-3 flex gap-1.5">
                        <button onclick="filterRole(this, 'All')"
                                class="filter-btn bg-[#1B2B5E] text-white border border-[#1B2B5E] rounded-full px-3.5 py-1 text-[11px] font-semibold">
                            All
                        </button>
                        <button onclick="filterRole(this, 'Student')"
                                class="filter-btn bg-transparent border border-slate-200 rounded-full px-3.5 py-1 text-[11px] font-semibold text-slate-500 hover:border-[#1B2B5E] hover:text-[#1B2B5E] transition-colors">
                            Student
                        </button>
<button onclick="filterRole(this, 'Professor')"
                                class="filter-btn bg-transparent border border-slate-200 rounded-full px-3.5 py-1 text-[11px] font-semibold text-slate-500 hover:border-[#1B2B5E] hover:text-[#1B2B5E] transition-colors">
                            Professor
                        </button>
                    </div>

                    @* Table *@
                    <div class="overflow-x-auto">
                        <table id="usersTable" class="w-full border-collapse text-xs">
                            <thead>
                                <tr class="bg-[#1B2B5E]">
                                    <th class="px-3.5 py-2.5 text-white text-left font-semibold text-[11px] whitespace-nowrap">ID / Emp. No.</th>
                                    <th class="px-3.5 py-2.5 text-white text-left font-semibold text-[11px] whitespace-nowrap">Last Name</th>
                                    <th class="px-3.5 py-2.5 text-white text-left font-semibold text-[11px] whitespace-nowrap">First Name</th>
                                    <th class="px-3.5 py-2.5 text-white text-left font-semibold text-[11px] whitespace-nowrap">Role</th>
                                    <th class="px-3.5 py-2.5 text-white text-left font-semibold text-[11px] whitespace-nowrap">Email</th>
                                    <th class="px-3.5 py-2.5 text-white text-left font-semibold text-[11px] whitespace-nowrap">Status</th>
                                    <th class="px-3.5 py-2.5 text-white text-center font-semibold text-[11px] whitespace-nowrap">Edit</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model)
                                {
                                    <tr data-role="@user.Role" class="even:bg-slate-50 hover:bg-slate-50 border-b border-slate-100 last:border-b-0">
                                        <td class="px-3.5 py-2.5 text-slate-700 whitespace-nowrap">@(user.StudId ?? user.EmpId)</td>
                                        <td class="px-3.5 py-2.5 text-slate-700">@user.LastName</td>
                                        <td class="px-3.5 py-2.5 text-slate-700">@user.FirstName</td>
                                        <td class="px-3.5 py-2.5">
                                            @{
                                                var roleBg = user.Role == "Student" ? "bg-blue-100 text-blue-700"
                                                : "bg-amber-100 text-amber-800";
                                            }
                                            <span class="@roleBg rounded-full px-2.5 py-0.5 text-[11px] font-semibold">@user.Role</span>
                                        </td>
                                        <td class="px-3.5 py-2.5 text-slate-700 whitespace-nowrap">@user.Email</td>
                                        <td class="px-3.5 py-2.5">
                                            <span class="bg-green-100 text-green-700 rounded-full px-2.5 py-0.5 text-[11px] font-semibold">@user.Status</span>
                                        </td>
                                        <td class="px-3.5 py-2.5 text-center">
                                            <a href="/MIS/UserInfo?id=@user.Id"
                                               title="Manage this account"
                                               class="inline-flex items-center justify-center w-[30px] h-[30px] bg-[#1B2B5E] text-white rounded-md text-sm no-underline hover:bg-blue-600 transition-colors">
                                                &#9998;
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                @* Archived Users Collapsible *@
                <div class="bg-white rounded-[10px] border border-slate-200 overflow-hidden mt-5">
                    <button onclick="toggleArchived()"
                            class="w-full px-5 py-3.5 flex justify-between items-center text-left hover:bg-slate-50 transition-colors">
                        <span class="text-base font-bold text-slate-500">
                            &#128452; Archived Users
                            <span class="ml-2 text-[11px] font-semibold bg-slate-100 text-slate-500 rounded-full px-2 py-0.5">
                                @((ViewBag.ArchivedUsers as List<BookHive.Models.User>)?.Count ?? 0)
                            </span>
                        </span>
                        <span id="archivedArrow" class="text-slate-400 text-lg transition-transform duration-200">&#8964;</span>
                    </button>

                    <div id="archivedSection" class="hidden overflow-x-auto border-t border-slate-100">
                        @{
                            var archivedList = ViewBag.ArchivedUsers as List<BookHive.Models.User> ?? new();
                        }
                        @if (!archivedList.Any())
                        {
                            <p class="text-center text-xs text-slate-400 py-6">No archived users.</p>
                        }
                        else
                        {
                            <table class="w-full border-collapse text-xs">
                                <thead>
                                    <tr class="bg-slate-200">
                                        <th class="px-3.5 py-2.5 text-slate-600 text-left font-semibold text-[11px] whitespace-nowrap">ID / Emp. No.</th>
                                        <th class="px-3.5 py-2.5 text-slate-600 text-left font-semibold text-[11px] whitespace-nowrap">Last Name</th>
                                        <th class="px-3.5 py-2.5 text-slate-600 text-left font-semibold text-[11px] whitespace-nowrap">First Name</th>
                                        <th class="px-3.5 py-2.5 text-slate-600 text-left font-semibold text-[11px] whitespace-nowrap">Role</th>
                                        <th class="px-3.5 py-2.5 text-slate-600 text-left font-semibold text-[11px] whitespace-nowrap">Email</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in archivedList)
                                    {
                                        <tr class="even:bg-slate-50 border-b border-slate-100 last:border-b-0">
                                            <td class="px-3.5 py-2.5 text-slate-400 whitespace-nowrap">@(user.StudId ?? user.EmpId)</td>
                                            <td class="px-3.5 py-2.5 text-slate-400">@user.LastName</td>
                                            <td class="px-3.5 py-2.5 text-slate-400">@user.FirstName</td>
                                            <td class="px-3.5 py-2.5">
                                                @{
                                                    var roleBg = user.Role == "Student" ? "bg-blue-50 text-blue-400"
                                                    : "bg-amber-50 text-amber-400";
                                                }
                                                <span class="@roleBg rounded-full px-2.5 py-0.5 text-[11px] font-semibold">@user.Role</span>
                                            </td>
                                            <td class="px-3.5 py-2.5 text-slate-400 whitespace-nowrap">@user.Email</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>

            </main>
        </div>
    </div>

    <script>
        function toggleArchived() {
            const section = document.getElementById('archivedSection');
            const arrow = document.getElementById('archivedArrow');
            const isHidden = section.classList.contains('hidden');
            section.classList.toggle('hidden', !isHidden);
            arrow.style.transform = isHidden ? 'rotate(180deg)' : '';
        }
    </script>
    <script src="~/js/mis-dashboard.js"></script>
    <script>
        function toggleUserMenu() {
            const menu = document.getElementById('userSubMenu');
            const arrow = document.getElementById('userMenuArrow');
            const isHidden = menu.style.display === 'none';
            menu.style.display = isHidden ? 'flex' : 'none';
            arrow.style.transform = isHidden ? 'rotate(180deg)' : '';
        }
    </script>
</body>
</html>